{
  "name": "@sajkatav/cli",
  "version": "1.0.0",
  "description": "CLI for the agentic pipeline — connects to Copilot via the VS Code bridge",
  "type": "module",
  "bin": {
    "sajkatav": "./bin/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "swc src -d dist --strip-leading-paths && tsc --emitDeclarationOnly",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "start": "node bin/index.js"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT"
}
