{
  "name": "sajkatav-vscode-extension",
  "displayName": "Sajkatav",
  "description": "Orchestrator → Spec → Coder → Tester pipeline via GitHub Copilot",
  "version": "1.0.0",
  "publisher": "4spergus",
  "repository": {
    "type": "git",
    "url": "https://github.com/4spergus/sajkatav.git",
    "directory": "packages/vscode-extension"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "AI",
    "Programming Languages",
    "Testing"
  ],
  "activationEvents": [
    "onCommand:sajkatav.run",
    "onCommand:sajkatav.startBridge",
    "onCommand:sajkatav.stopBridge"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "build": "node build.js",
    "typecheck": "tsc --noEmit",
    "watch": "node build.js --watch",
    "package": "npx @vscode/vsce package --no-dependencies"
  },
  "contributes": {
    "chatParticipants": [
      {
        "id": "sajkatav.agent",
        "fullName": "Sajkatav",
        "name": "pipeline",
        "description": "Run the Orchestrator → Spec → Coder → Tester pipeline",
        "isSticky": true,
        "commands": [
          {
            "name": "run",
            "description": "Run the full pipeline"
          },
          {
            "name": "plan",
            "description": "Orchestrator: create a plan"
          },
          {
            "name": "spec",
            "description": "Spec Generator: create file specs"
          },
          {
            "name": "code",
            "description": "Coder: implement from plan/spec"
          },
          {
            "name": "test",
            "description": "Tester: generate unit tests"
          }
        ]
      }
    ],
    "commands": [
      {
        "command": "sajkatav.run",
        "title": "Sajkatav: Run"
      },
      {
        "command": "sajkatav.startBridge",
        "title": "Sajkatav: Start CLI Bridge"
      },
      {
        "command": "sajkatav.stopBridge",
        "title": "Sajkatav: Stop CLI Bridge"
      }
    ],
    "configuration": {
      "title": "Sajkatav",
      "properties": {
        "sajkatav.models.orchestrator": {
          "type": "string",
          "default": "gpt-4o",
          "description": "Model for the Orchestrator"
        },
        "sajkatav.models.specGenerator": {
          "type": "string",
          "default": "gpt-4o",
          "description": "Model for the Spec Generator"
        },
        "sajkatav.models.coder": {
          "type": "string",
          "default": "gpt-4o",
          "description": "Model for the Coder"
        },
        "sajkatav.models.tester": {
          "type": "string",
          "default": "gpt-4o",
          "description": "Model for the Tester"
        },
        "sajkatav.tester.framework": {
          "type": "string",
          "enum": [
            "vitest",
            "jest",
            "node:test"
          ],
          "default": "vitest",
          "description": "Test framework"
        },
        "sajkatav.bridge.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "Auto-start the CLI bridge server on activation"
        },
        "sajkatav.bridge.port": {
          "type": "number",
          "default": 9786,
          "description": "Port for the CLI bridge server"
        },
        "sajkatav.freeTier.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable free tier models (GPT-4o, GPT-4.1) for the pipeline"
        },
        "sajkatav.freeTier.models": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "GPT-4o",
            "GPT-4.1"
          ],
          "description": "Free tier models available for the pipeline"
        }
      }
    }
  },
  "devDependencies": {
    "@sajkatav/core": "1.0.0",
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.93.0",
    "esbuild": "^0.24.0"
  },
  "extensionDependencies": [
    "github.copilot-chat"
  ]
}
