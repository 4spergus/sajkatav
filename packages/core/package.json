{
  "name": "@sajkatav/core",
  "version": "1.0.0",
  "description": "Configurable agentic pipeline library — Orchestrator, Spec Generator, Coder, Tester — powered by Copilot",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "swc src -d dist --strip-leading-paths && tsc --emitDeclarationOnly",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "test": "node --test dist/**/*.test.js"
  },
  "dependencies": {
    "eventemitter3": "^5.0.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "sajkatav",
    "core",
    "copilot",
    "ai",
    "agents",
    "orchestrator"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/4spergus/sajkatav.git",
    "directory": "packages/core"
  },
  "license": "MIT"
}
